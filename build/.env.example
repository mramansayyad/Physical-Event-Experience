# Aman Tech Innovations - Real-Time Stadium Backend
# Infrastructure & Deployment Environment Targets

# Core Project Topology
GOOGLE_CLOUD_PROJECT="virtual-promptwars-492614"
DEPLOY_REGION="us-central1"

# External Database & Message Brokers 
FIRESTORE_COLLECTION="heatmaps"
PUBSUB_TOPIC="telemetry-stream"

# Subnet & VPC Configurations (Serverless Scaling)
VPC_NETWORK_NAME="stadium-vpc"
SUBNET_NAME="stadium-serverless-subnet"
VPC_CONNECTOR_NAME="stadium-redis-bridge"

# Kubernetes / Cloud Run Knative Parameters
MIN_INSTANCES="2"
MAX_INSTANCES="100"
CONCURRENCY="80"
CPU_THROTTLING_ENABLED="false"

# Terraform Shared State Target (GCS)
TF_BACKEND_BUCKET="stadium-tf-state-secure"

# Disaster Recovery (The Big Red Button)
# Switch to 'true' only if VPC Peer or Redis degrades to force standard un-batched Firestore writes
DIRECT_FIRESTORE_OVERRIDE="false"

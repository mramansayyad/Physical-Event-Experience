{
  "displayName": "Stadium Architecture - Halftime Rush Overview",
  "mosaicLayout": {
    "columns": 12,
    "tiles": [
      {
        "yPos": 0,
        "xPos": 0,
        "width": 12,
        "height": 4,
        "widget": {
          "title": "Pub/Sub Message Age (Latency)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"pubsub.googleapis.com/subscription/oldest_unacked_message_age\" resource.type=\"pubsub_subscription\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_MAX"
                    }
                  }
                }
              }
            ]
          }
        }
      },
      {
        "yPos": 4,
        "xPos": 0,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Cloud Run Instance Count vs CPU",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"run.googleapis.com/container/instance_count\" resource.type=\"cloud_run_revision\"",
                    "aggregation": { "perSeriesAligner": "ALIGN_MEAN" }
                  }
                }
              },
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"run.googleapis.com/container/cpu/utilizations\" resource.type=\"cloud_run_revision\"",
                    "aggregation": { "perSeriesAligner": "ALIGN_MEAN" }
                  }
                }
              }
            ]
          }
        }
      },
      {
        "yPos": 4,
        "xPos": 6,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Firestore Write Throttles",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"firestore.googleapis.com/api/write_throttling_events\" resource.type=\"datastore_database\"",
                    "aggregation": { "alignmentPeriod": "60s", "perSeriesAligner": "ALIGN_SUM" }
                  }
                }
              }
            ]
          }
        }
      }
    ]
  }
}
